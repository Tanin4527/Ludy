# =========================================================================
# Rule Name: LudyServer & Comprehensive Local Network Bypass
# Target App: LudyServer - File Transfer (App Store ID: 6759769077)
# Purpose: Force DIRECT for local Wi-Fi server (HTTP/WebDAV/SFTP), mDNS/Bonjour, private IPs
# Key Fixes: Prioritize .local domains, explicit DIRECT policy, full RFC1918 + link-local
# Environment: IPv4/IPv6 dual-stack, Loon/Surge/Quantumult X compatible
# Version: v1.1.0 (2026-03)
# =========================================================================

# === Priority: Highest - Developer & App Core Domains ===
DOMAIN-SUFFIX,local,DIRECT
DOMAIN-SUFFIX,ludy.app,DIRECT
DOMAIN,ludy.app,DIRECT
DOMAIN-KEYWORD,.local,DIRECT
DOMAIN-KEYWORD,ludy,DIRECT
DOMAIN-KEYWORD,ankas,DIRECT

# === Multicast / Broadcast / Service Discovery (mDNS, SSDP, etc.) ===
IP-CIDR,224.0.0.0/4,DIRECT,no-resolve
IP-CIDR,239.255.255.250/32,DIRECT,no-resolve     # SSDP common
IP-CIDR,255.255.255.255/32,DIRECT,no-resolve

# === Full Private IPv4 Ranges (RFC 1918 + link-local + loopback) ===
IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
IP-CIDR,169.254.0.0/16,DIRECT,no-resolve         # link-local / APIPA
IP-CIDR,127.0.0.0/8,DIRECT,no-resolve            # loopback

# === IPv6 ULA / Link-local / Loopback ===
IP-CIDR6,fe80::/10,DIRECT,no-resolve
IP-CIDR6,fc00::/7,DIRECT,no-resolve              # Unique Local Address (ULA)
IP-CIDR6,::1/128,DIRECT,no-resolve

# End of LudyServer rules - place this RULE-SET at the VERY TOP of your [Rule] section
